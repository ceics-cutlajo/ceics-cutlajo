{
  "name": "ceics-cutlajo",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma del Comité de Ética en Investigación en Ciencias de la Salud — CUTlajomulco · UDG",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:types": "supabase gen types typescript --linked > src/types/database.types.ts",
    "db:seed": "supabase db reset && echo 'Migraciones y seeds aplicadas'",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\""
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@hookform/resolvers": "^3.9.1",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.46.1",
    "@vercel/analytics": "^2.0.1",
    "clsx": "^2.1.1",
    "docx": "^9.6.1",
    "lucide-react": "^0.453.0",
    "mammoth": "^1.8.0",
    "next": "^16.2.6",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.2",
    "tailwind-merge": "^2.5.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20"
  }
}
