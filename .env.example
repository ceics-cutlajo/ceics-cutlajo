# =============================================================
# CEICS CUTLAJO — Variables de entorno
# Copia este archivo como `.env.local` y llena con tus credenciales reales.
# NUNCA subas .env.local a Git.
# =============================================================

# --- Supabase (obtener en supabase.com → Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx.xxx
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxx.xxx
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# --- Resend (obtener en resend.com → API Keys) ---
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=CEICS CUTLAJO <onboarding@resend.dev>

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CEICS CUTLAJO

# --- Cowork webhook (para Scheduled Tasks de IA) ---
COWORK_WEBHOOK_SECRET=generate-a-random-32-char-string-here

# --- Modo de desarrollo ---
NODE_ENV=development
